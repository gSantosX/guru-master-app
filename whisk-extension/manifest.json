{
  "manifest_version": 3,
  "name": "Auto Whisk Companion",
  "version": "1.0.0",
  "description": "Companion for Guru Master to automate Google Labs Whisk.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://labs.google/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://labs.google/fx/*/tools/whisk*"],
      "js": ["content.js"]
    }
  ]
}
